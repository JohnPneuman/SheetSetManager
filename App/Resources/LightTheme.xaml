<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBackground"         Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SubtleBackground"        Color="#F5F9FF"/>
    <SolidColorBrush x:Key="HeaderBackground"        Color="#F5F5F5"/>
    <SolidColorBrush x:Key="InputBackground"         Color="Transparent"/>
    <SolidColorBrush x:Key="TreeBackground"          Color="White"/>
    <SolidColorBrush x:Key="AltRowBackground"        Color="#F5F9FF"/>
    <SolidColorBrush x:Key="SelectedBackground"      Color="#E3F2FD"/>
    <SolidColorBrush x:Key="HoverBackground"         Color="#F0F0F0"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"             Color="#D0D0D0"/>
    <SolidColorBrush x:Key="SubtleBorder"            Color="#E8E8E8"/>
    <SolidColorBrush x:Key="InputBorder"             Color="#DDDDDD"/>
    <SolidColorBrush x:Key="SeparatorBrush"          Color="#BDBDBD"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"             Color="#222222"/>
    <SolidColorBrush x:Key="TextSecondary"           Color="#444444"/>
    <SolidColorBrush x:Key="TextMuted"               Color="#888888"/>
    <SolidColorBrush x:Key="TextDisabled"            Color="#999999"/>
    <SolidColorBrush x:Key="TextInverted"            Color="#FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"             Color="#1976D2"/>
    <SolidColorBrush x:Key="AccentLight"             Color="#BBDEFB"/>
    <SolidColorBrush x:Key="AccentBorder"            Color="#1976D2"/>
    <SolidColorBrush x:Key="SelectedBorder"          Color="#1976D2"/>

    <!-- Status -->
    <SolidColorBrush x:Key="ErrorBrush"              Color="#E53935"/>
    <SolidColorBrush x:Key="SuccessBrush"            Color="#388E3C"/>
    <SolidColorBrush x:Key="WarningBrush"            Color="#F57C00"/>

    <!-- GroupBox / Expander -->
    <SolidColorBrush x:Key="GroupBoxBorder"          Color="#2196F3"/>
    <SolidColorBrush x:Key="ExpanderBorder"          Color="#90CAF9"/>

    <!-- Button -->
    <SolidColorBrush x:Key="ButtonBackground"        Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ButtonForeground"        Color="#222222"/>
    <SolidColorBrush x:Key="ButtonBorder"            Color="#BDBDBD"/>

</ResourceDictionary>
