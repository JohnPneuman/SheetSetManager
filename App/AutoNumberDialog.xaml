<Window x:Class="SheetSetEditor.AutoNumberDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoNumber opties" Height="230" Width="260"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Startnummer:"  VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="StartBox"    Text="1" Height="24" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Stap:"         VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="IncrementBox" Text="1" Height="24" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Prefix:"       VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="PrefixBox"   Height="24" Margin="0,0,0,8" Padding="3,0" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Suffix:"       VerticalAlignment="Center"/>
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="SuffixBox"   Height="24" Padding="3,0" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"         Width="65" Height="26" Margin="0,0,6,0"
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="Annuleren"  Width="80" Height="26" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
