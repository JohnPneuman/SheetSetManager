<Window x:Class="SheetSetEditor.Options.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:SheetSetEditor.Services"
        Title="{Binding [OptionsTitle], Source={x:Static services:LocalizationService.Instance}}"
        Height="460" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextPrimary}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Appearance ── -->
        <GroupBox Grid.Row="0"
                  Header="{Binding [Appearance], Source={x:Static services:LocalizationService.Instance}}"
                  BorderBrush="{DynamicResource GroupBoxBorder}" BorderThickness="1.5"
                  Padding="10,8" Foreground="{DynamicResource TextPrimary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Language -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding [Language], Source={x:Static services:LocalizationService.Instance}}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <ComboBox  x:Name="LanguageCombo" Grid.Row="0" Grid.Column="1"
                           Height="26" SelectionChanged="LanguageCombo_SelectionChanged"/>

                <!-- Theme -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding [Theme], Source={x:Static services:LocalizationService.Instance}}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <RadioButton x:Name="LightRadio"
                                 Content="{Binding [LightMode], Source={x:Static services:LocalizationService.Instance}}"
                                 GroupName="Theme" Margin="0,0,16,0"
                                 VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"
                                 Checked="Theme_Changed"/>
                    <RadioButton x:Name="DarkRadio"
                                 Content="{Binding [DarkMode], Source={x:Static services:LocalizationService.Instance}}"
                                 GroupName="Theme"
                                 VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"
                                 Checked="Theme_Changed"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- ── General ── -->
        <GroupBox Grid.Row="2"
                  Header="{Binding [General], Source={x:Static services:LocalizationService.Instance}}"
                  BorderBrush="{DynamicResource GroupBoxBorder}" BorderThickness="1.5"
                  Padding="10,8" Foreground="{DynamicResource TextPrimary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Auto backup -->
                <CheckBox x:Name="AutoBackupCheck" Grid.Row="0" Grid.ColumnSpan="2"
                          Content="{Binding [AutoBackup], Source={x:Static services:LocalizationService.Instance}}"
                          VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>

                <!-- Max recent files -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding [RecentFilesCount], Source={x:Static services:LocalizationService.Instance}}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                <TextBox   x:Name="MaxRecentBox" Grid.Row="2" Grid.Column="1"
                           Width="60" Height="24" Padding="4,2"
                           VerticalContentAlignment="Center"
                           Background="{DynamicResource InputBackground}"
                           Foreground="{DynamicResource TextPrimary}"
                           BorderBrush="{DynamicResource InputBorder}"/>
            </Grid>
        </GroupBox>

        <!-- ── Language display names ── -->
        <GroupBox Grid.Row="4"
                  Header="🌍"
                  BorderBrush="{DynamicResource SubtleBorder}" BorderThickness="1"
                  Padding="10,6" Foreground="{DynamicResource TextMuted}">
            <WrapPanel>
                <TextBlock Text="🇳🇱 Nederlands  " Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🇬🇧 English  "    Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🇩🇪 Deutsch  "    Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🇫🇷 Français  "   Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🇿🇦 Afrikaans  "  Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🏴 Frysk  "       Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                <TextBlock Text="🖖 tlhIngan Hol"  Foreground="{DynamicResource TextMuted}" FontSize="11"/>
            </WrapPanel>
        </GroupBox>

        <!-- ── Buttons ── -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Width="80" Height="28" Margin="0,0,8,0"
                    Content="{Binding [OK], Source={x:Static services:LocalizationService.Instance}}"
                    IsDefault="True" Click="Ok_Click"/>
            <Button x:Name="CancelButton" Width="80" Height="28"
                    Content="{Binding [Cancel], Source={x:Static services:LocalizationService.Instance}}"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
