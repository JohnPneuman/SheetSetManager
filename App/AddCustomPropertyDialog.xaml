<Window x:Class="SheetSetEditor.AddCustomPropertyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nieuwe custom property" Height="190" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Naam:"
                   VerticalAlignment="Center" Foreground="#444"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox"
                   Height="26" Padding="4,2" VerticalContentAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:"
                   VerticalAlignment="Top" Margin="0,4,0,0" Foreground="#444"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,3,0,0">
            <RadioButton x:Name="RbBladVeld"
                         Content="Blad veld  (waarde verschilt per blad)"
                         IsChecked="True" Margin="0,0,0,7"/>
            <RadioButton x:Name="RbSheetsetVeld"
                         Content="Sheetset veld  (één waarde voor de hele set)"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="26" Margin="0,0,6,0"
                    IsDefault="True" Click="OkButton_Click"/>
            <Button Content="Annuleren" Width="80" Height="26" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
