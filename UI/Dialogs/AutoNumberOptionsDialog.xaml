<Window x:Class="BoekSolutions.SheetSetEditor.UI.Dialogs.AutoNumberOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoNumber Options" Height="180" Width="200" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Start number:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="StartNumberBox" Width="50" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Increment:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="IncrementBox" Width="50" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Prefix:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="PrefixBox" Width="100" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Suffix:" Width="80" VerticalAlignment="Center"/>
            <TextBox x:Name="SuffixBox" Width="100" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="OK" Width="50" Margin="5,0" IsDefault="True" Click="OnOkClicked" Height="25" />
            <Button Content="Cancel" Width="50" Margin="5,0" IsCancel="True" Height="25" />
        </StackPanel>
    </Grid>
</Window>
