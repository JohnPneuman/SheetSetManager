<UserControl x:Class="BoekSolutions.SheetSetEditor.UI.Controls.AutoNumberControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Height="Auto" Width="Auto">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Label + Startnummer -->
        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="Start number:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="StartNumberBox" Width="50" VerticalAlignment="Center" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- AutoNumber knop -->
        <Button Grid.Column="1"
                Content="AutoNumber"
                Width="100"
                Margin="0,0,10,0"
                Click="OnAutoNumberClicked" />

        <!-- Opties knop -->
        <Button Grid.Column="2"
                Content="Options"
                Width="75"
                Click="OnOptionsClicked" />
    </Grid>
</UserControl>
